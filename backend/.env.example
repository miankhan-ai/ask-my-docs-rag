# Copy to .env and fill in. The defaults below run the app fully locally
# with no Docker, no Postgres, and no HuggingFace key.

# --- LLM (generation) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Embeddings ---
# local = on-device sentence-transformers (no key/network). api = HuggingFace Inference API.
EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Only used when EMBEDDING_BACKEND=api
HF_API_KEY=
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# --- Storage backend ---
# sqlite = zero-infra local mode (embeddings as JSON, cosine in Python).
# postgres = pgvector (production). DATABASE_URL_OVERRIDE wins if set.
DB_BACKEND=sqlite
# DATABASE_URL_OVERRIDE=postgresql+asyncpg://askdocs:askdocs@localhost:5432/askdocs

# --- Retrieval / chunking ---
BM25_TOP_N=20
DENSE_TOP_N=20
RRF_K=60
RERANKER_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_BATCH_SIZE=100
BM25_INDEX_PATH=data/bm25_index.pkl

# --- Observability ---
LOG_LEVEL=INFO
METRICS_ENABLED=true
# USD per 1k tokens, for cost accounting (Groq free tier is $0).
LLM_PRICE_IN_PER_1K=0.00059
LLM_PRICE_OUT_PER_1K=0.00079

# --- Caching ---
# cache_backend: "memory" (zero-infra default) or "redis"
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_TTL_S=86400
EMBEDDING_CACHE_MAX_SIZE=10000
# Semantic answer cache (off by default — correctness-sensitive)
ANSWER_CACHE_ENABLED=false
ANSWER_CACHE_TTL_S=3600
ANSWER_CACHE_MAX_SIZE=1000
ANSWER_CACHE_SIMILARITY_THRESHOLD=0.95
