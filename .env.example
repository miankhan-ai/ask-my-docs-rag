# LLM
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Embeddings
# EMBEDDING_BACKEND: "api" uses the HuggingFace Inference API (needs HF_API_KEY
# + network); "local" computes embeddings on-device via sentence-transformers
# (no key, no network — slower first run while the model downloads).
EMBEDDING_BACKEND=api
HF_API_KEY=your_hf_api_key
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Database
DATABASE_URL=postgresql+asyncpg://askdocs:askdocs@localhost:5432/askdocs

# Retrieval
BM25_TOP_N=20
DENSE_TOP_N=20
RRF_K=60
RERANKER_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_BATCH_SIZE=100

# BM25 persistence
BM25_INDEX_PATH=data/bm25_index.pkl
