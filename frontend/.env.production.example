# Production build configuration for the frontend.
#
# Copy this file to `.env.production` and set VITE_API_BASE to your deployed
# backend URL (the Hugging Face Space). Vite inlines this at build time when you
# run `npm run build`, so the static site on Hostinger knows where the API lives.
#
# The live backend Space for this project:
VITE_API_BASE=https://miankhanai-ask-my-docs-backend.hf.space
